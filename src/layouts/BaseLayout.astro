---
import Header from '../components/Header.astro';
import SeoHead from '../components/SeoHead.astro';
import Footer from '../components/Footer.astro';
import { SITE, absoluteUrl } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  bodyClass?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  canonical,
  bodyClass = '',
  image,
  type,
  publishedTime,
  modifiedTime,
  noindex,
  jsonLd,
} = Astro.props;

const siteJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: absoluteUrl('/images/social/default-og.png'),
    founder: {
      '@type': 'Person',
      name: SITE.author,
    },
  },
];

const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...siteJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f7f9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c1418" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500..800&family=Literata:ital,opsz,wght@0,7..72,400..700;1,7..72,400..600&family=Spline+Sans+Mono:wght@400..700&display=swap"
    />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
      jsonLd={allJsonLd}
    />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      const header = document.querySelector('.site-header');
      if (header) {
        const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
