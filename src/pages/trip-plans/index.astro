---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/seo';

const tripPlans = await getCollection('trip-plans');
const sortedPlans = tripPlans.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/') },
    { '@type': 'ListItem', position: 2, name: 'Trip plans', item: absoluteUrl('/trip-plans/') },
  ],
};
---

<BaseLayout
  title="Trip Plans"
  description="Independent trip plans with real logistics, costs, hotels, and honest pacing notes."
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <p class="tag">Trip library</p>
    <h1>Routes built from actual travel</h1>
    <p>Not brochure arithmetic. Each plan fits a two or three week window, with enough comfort to enjoy the trip and enough independence to keep the price sane.</p>
  </section>

  <section class="plan-list">
    {sortedPlans.map((plan) => (
      <article class="plan-card">
        <p class="tag">{plan.data.duration} &middot; {plan.data.activity_level}</p>
        <h2><a href={`/trip-plans/${plan.id}/`}>{plan.data.title}</a></h2>
        <p>{plan.data.description}</p>
        <ul>
          {plan.data.countries.map((country) => <li>{country}</li>)}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>
