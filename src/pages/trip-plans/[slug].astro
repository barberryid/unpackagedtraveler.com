---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tripPhotosByPlan } from '../../data/tripPhotos';
import { tripMetaByPlan } from '../../data/tripMeta';
import { SITE, absoluteUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const tripPlans = await getCollection('trip-plans');
  return tripPlans.map((plan) => ({
    params: { slug: plan.id },
    props: { plan },
  }));
}

const { plan } = Astro.props;
const { Content } = await render(plan);
const planPhotos = tripPhotosByPlan[plan.id] ?? [];
const meta = tripMetaByPlan[plan.id];
const formattedDate = plan.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const canonicalPath = `/trip-plans/${plan.id}/`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: plan.data.title,
    description: plan.data.description,
    image: meta ? absoluteUrl(meta.hero.src) : absoluteUrl('/images/social/default-og.png'),
    datePublished: plan.data.date.toISOString(),
    dateModified: plan.data.date.toISOString(),
    author: {
      '@type': 'Person',
      name: plan.data.author,
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      logo: {
        '@type': 'ImageObject',
        url: absoluteUrl('/images/social/default-og.png'),
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': absoluteUrl(canonicalPath),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/') },
      { '@type': 'ListItem', position: 2, name: 'Trip plans', item: absoluteUrl('/trip-plans/') },
      { '@type': 'ListItem', position: 3, name: plan.data.title, item: absoluteUrl(canonicalPath) },
    ],
  },
];
---

<BaseLayout
  title={plan.data.title}
  description={plan.data.description}
  canonical={canonicalPath}
  image={meta?.hero.src}
  type="article"
  publishedTime={plan.data.date}
  jsonLd={jsonLd}
>
  <article class="article-shell">
    <header class="article-header">
      <p class="tag">{plan.data.duration} &middot; {plan.data.activity_level} &middot; Updated {formattedDate}</p>
      <div class="country-list">
        {plan.data.countries.map((country) => <span>{country}</span>)}
      </div>
    </header>
    <div class="article-body">
      <Content />
    </div>
    {planPhotos.length > 0 && (
      <section class="photo-gallery-section" aria-labelledby="route-photos-heading">
        <div class="section-kicker">
          <p class="tag">Route in photos</p>
          <div class="kicker-row">
            <h2 id="route-photos-heading">What the route actually looked like</h2>
            <span class="kicker-rule" aria-hidden="true"></span>
            <span class="kicker-meta">{planPhotos.length} photos &middot; {plan.data.duration}</span>
          </div>
        </div>
        <div class="photo-grid">
          {planPhotos.map((photo) => (
            <figure class="photo-card">
              <img src={photo.src} alt={photo.alt} loading="lazy" style={photo.pos ? `object-position: ${photo.pos}` : undefined} />
              <figcaption>
                <span>{photo.stop}</span>
                {photo.label}
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
