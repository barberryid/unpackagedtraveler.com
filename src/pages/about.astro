---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Gary Wilson and The Unpackaged Traveler.">
  <section class="page-hero compact">
    <p class="tag">About</p>
    <h1>The playbook, not the package</h1>
    <p>
      The Unpackaged Traveler is written by Gary Wilson after 25 years of learning how to travel well for less in 154 countries.
    </p>
  </section>
  <section class="section split-copy">
    <div>
      <h2>The promise</h2>
      <p>
        These are independent trip plans with real logistics: which transfer works, where to sleep, what the day actually feels like, and where the money goes.
      </p>
    </div>
    <div>
      <h2>The reader</h2>
      <p>
        US retirees and near-retirees who still want movement, texture, and discovery, but prefer clear pacing and fewer expensive surprises.
      </p>
    </div>
  </section>
</BaseLayout>
