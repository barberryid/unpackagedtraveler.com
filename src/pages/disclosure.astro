---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Affiliate Disclosure" description="Affiliate disclosure for The Unpackaged Traveler.">
  <section class="page-hero compact">
    <p class="tag">Disclosure</p>
    <h1>Affiliate disclosure</h1>
    <p>
      Some future links on this site may earn a commission if you book through them, at no extra cost to you.
    </p>
  </section>
  <section class="section readable">
    <p>
      Recommendations are based on fit, value, location, and first-hand or clearly labelled research. Affiliate relationships will never be allowed to decide whether a place or product is included.
    </p>
    <p>
      This page exists before affiliate links go live so the site is ready for US FTC compliance from the start.
    </p>
  </section>
</BaseLayout>
