---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscribe" description="Subscribe free to The Unpackaged Traveler.">
  <section class="page-hero compact">
    <p class="eyebrow">Subscribe</p>
    <h1>New trip plans land in subscribers' inboxes first.</h1>
    <p>Weekly notes, with one full route plan each month and lighter travel intelligence between them.</p>
  </section>
  <section class="section newsletter-card">
    <form class="signup-form large" action="#" method="post">
      <label>
        <span>Email address</span>
        <input type="email" name="email" placeholder="you@example.com" />
      </label>
      <button type="submit">Subscribe free</button>
    </form>
  </section>
</BaseLayout>
